    {
      "type": "stat",
      "title": "💧 Water Pump",
      "id": 14,
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 2 },
      "datasource": { "type": "influxdb", "uid": "influxdb-sim" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "displayName": "Water Pump",
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "OFF", "color": "blue",  "index": 0 },
                "1": { "text": "ON",  "color": "green", "index": 1 }
              }
            },
            {
              "type": "special",
              "options": { "match": "null", "result": { "text": "—", "color": "text" } }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue",  "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "noValue": "No signal"
      },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "influxdb-sim" },
        "query": "from(bucket: \"sim_telemetry\")\n  |> range(start: -30d)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"waterpump\")\n  |> filter(fn: (r) => r[\"_field\"] == \"set\")\n  |> last()",
        "refId": "A"
      }]
    },

    {
      "type": "timeseries",
      "title": "🌡️ Temperature & 💧 Humidity",
      "id": 20,
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "influxdb", "uid": "influxdb-sim" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 8, "spanNulls": false }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": [
              { "id": "displayName",          "value": "Temperature" },
              { "id": "unit",                 "value": "celsius" },
              { "id": "color",                "value": { "mode": "fixed", "fixedColor": "orange" } },
              { "id": "custom.axisPlacement", "value": "left" },
              { "id": "custom.axisLabel",     "value": "°C" }
            ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [
              { "id": "displayName",          "value": "Humidity" },
              { "id": "unit",                 "value": "percent" },
              { "id": "color",                "value": { "mode": "fixed", "fixedColor": "blue" } },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.axisLabel",     "value": "%" }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["min", "max", "mean", "last"] }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-sim" },
          "query": "from(bucket: \"sim_telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"dht\")\n  |> filter(fn: (r) => r[\"_field\"] == \"temp\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)",
          "refId": "A"
        },
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-sim" },
          "query": "from(bucket: \"sim_telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"dht\")\n  |> filter(fn: (r) => r[\"_field\"] == \"hum\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)",
          "refId": "B"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "💧 Water Pump — Activation History",
      "description": "Step chart: ON = 1, OFF = 0. Threshold area highlights active irrigation periods.",
      "id": 21,
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "influxdb", "uid": "influxdb-sim" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 1,
          "displayName": "Pump state",
          "color": { "mode": "fixed", "fixedColor": "green" },
          "mappings": [
            { "type": "value", "options": {
                "0": { "text": "OFF" },
                "1": { "text": "ON"  }
            }}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "green",       "value": 1 }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "spanNulls": true,
            "lineInterpolation": "stepAfter",
            "thresholdsStyle": { "mode": "area" },
            "axisSoftMin": 0,
            "axisSoftMax": 1,
            "axisColorMode": "text",
            "axisLabel": "State",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false }
          }
        }
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "last"] },
        "yAxis": {
          "min": 0,
          "max": 1,
          "decimals": 0
        }
      },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "influxdb-sim" },
        "query": "from(bucket: \"sim_telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"waterpump\")\n  |> filter(fn: (r) => r[\"_field\"] == \"set\")\n  |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: false)",
        "refId": "A"
      }]
    },

