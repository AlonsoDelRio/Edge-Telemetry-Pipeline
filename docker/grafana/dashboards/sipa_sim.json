{
  "title": "SIPA — Simulator Telemetry",
  "uid": "sipa-sim-v1",
  "description": "Wokwi simulator data — bucket: sim_telemetry",
  "tags": ["sipa", "simulator", "wokwi"],
  "editable": false,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "graphTooltip": 1,
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "links": [
    {
      "title": "Switch to Hardware",
      "url": "/d/sipa-hw-v1",
      "type": "link",
      "icon": "external link",
      "tooltip": "Open Hardware dashboard"
    }
  ],
  "panels": [

    {
      "type": "text",
      "id": 1,
      "gridPos": { "h": 2, "w": 12, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "## 🖥️ Wokwi Simulator &nbsp;&nbsp;`esp32-00` &nbsp;&nbsp;`bucket: sim_telemetry`"
      }
    },

    {
      "type": "stat",
      "title": "📡 Device Status",
      "id": 8,
      "gridPos": { "h": 2, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "influxdb-sim" },
      "description": "ONLINE = data received in the last 10 seconds. OFFLINE = no signal from Wokwi.",
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "displayName": "Device Status",
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "type": "special",
              "options": { "match": "null",    "result": { "text": "OFFLINE", "color": "red"   } }
            },
            {
              "type": "special",
              "options": { "match": "novalue", "result": { "text": "OFFLINE", "color": "red"   } }
            },
            {
              "type": "range",
              "options": { "from": -1e10, "to": 1e10, "result": { "text": "ONLINE", "color": "green" } }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 0 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "noValue": "OFFLINE"
      },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "influxdb-sim" },
        "query": "from(bucket: \"sim_telemetry\")\n  |> range(start: -10s)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"dht\")\n  |> filter(fn: (r) => r[\"_field\"] == \"temp\")\n  |> last()",
        "refId": "A"
      }]
    },

    {
      "type": "stat",
      "title": "🕐 Last Reading",
      "id": 9,
      "gridPos": { "h": 2, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "influxdb-sim" },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "unit": "dateTimeAsUS",
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "limit": 1,
          "fields": "/^_time$/",
          "calcs": [ "last" ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value",
        "noValue": "No signal"
      },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "influxdb-sim" },
        "query": "from(bucket: \"sim_telemetry\")\r\n\r\n  |> range(start: -30d)\r\n  |> filter(fn: (r) => r[\"_measurement\"] == \"soil\")\r\n  |> last()\r\n  |> keep(columns: [\"_time\"])",
        "refId": "A"
      }]
    },

    {
      "type": "stat",
      "title": "🌡️ Temperature",
      "id": 10,
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 2 },
      "datasource": { "type": "influxdb", "uid": "influxdb-sim" },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "decimals": 1,
          "displayName": "Temperature",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue",   "value": null },
              { "color": "green",  "value": 15 },
              { "color": "yellow", "value": 30 },
              { "color": "red",    "value": 40 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name",
        "noValue": "No signal"
      },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "influxdb-sim" },
        "query": "from(bucket: \"sim_telemetry\")\n  |> range(start: -30d)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"dht\")\n  |> filter(fn: (r) => r[\"_field\"] == \"temp\")\n  |> last()",
        "refId": "A"
      }]
    },

