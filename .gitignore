# --- Influxdb ---
docker/secrets/env.influxdb
docker/influxdb/config/*
!docker/influxdb/config/.gitkeep
docker/influxdb/data/*
!docker/influxdb/data/.gitkeep

# --- Docker credentials ---
docker/.env

# --- Firmware (PlatformIO) ---
firmware/.pio/       
firmware/.vscode/*   
!firmware/.vscode/extensions.json
firmware/include/
firmware/lib/
firmware/test/
firmware/src/config/secrets.h

