# --- Mosquitto ---
docker/mosquitto/data/
docker/mosquitto/log/

# --- Node-RED ---
docker/nodered/data/*
!docker/nodered/data/flows.json
!docker/nodered/data/package.json
docker/nodered/data/lib/
docker/nodered/data/node_modules/
docker/nodered/data/.*
